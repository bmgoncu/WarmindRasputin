{
  "name": "rasputin-claude-ai",
  "description": "Warmind voice interface for Claude Code — Rasputin persona, audio-reactive orb overlay, observes and drives Claude sessions.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "lib/server/daemon.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "say": "tsx src/server/voice/say-cli.ts",
    "audition": "tsx src/server/voice/audition.ts",
    "analyze-ref": "tsx src/server/voice/analyze-ref.ts",
    "fit-eq": "tsx src/server/voice/fit-eq.ts",
    "check-pitch": "tsx src/server/voice/check-pitch.ts",
    "extract-ambience": "tsx src/server/audio/extract-ambience.ts",
    "orb": "vite",
    "orb:build": "vite build",
    "daemon": "tsx src/server/daemon.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "playwright": "^1.61.1",
    "three": "^0.185.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.5"
  }
}
