# Copy to .env (untracked) and adjust. Every value here is a safe local default —
# the daemon runs with none of them set.

# ── Daemon ────────────────────────────────────────────────────────────────────
RASPUTIN_PORT=7331
# Loopback only. Do not bind 0.0.0.0 — the hook endpoint is unauthenticated.
RASPUTIN_HOST=127.0.0.1

# ── Voice ─────────────────────────────────────────────────────────────────────
# `say -v ?` to list. Yuri (Enhanced) is a MALE ru_RU voice and renders English
# text with Russian phonetics — that accent is the whole point. Measured F0 96.8 Hz
# vs the reference's 80.5, so it needs only ~3 semitones of shift. Milena (the other
# ru_RU voice) is female at 215 Hz and needed 17 semitones, which sounded slowed-down.
# Yuri is NOT installed by default: System Settings > Accessibility > Spoken Content
# > System Voice > Manage Voices.
RASPUTIN_VOICE=Tom (Enhanced)
# Words per minute. Rasputin reads slow; 150 is the tuned default.
RASPUTIN_RATE=150
# Named chain preset from src/server/voice/chains.ts.
# warmind | measured | plain | og-warmind. A chain may name its own voice, which
# outranks RASPUTIN_VOICE above — og-warmind forces Yuri (Enhanced) and translates
# its input to Russian first, so an en-US voice there would defeat the point.
RASPUTIN_CHAIN=warmind

# ── Reference media ───────────────────────────────────────────────────────────
# Destiny 2 captures used as the spectral target for the firequalizer curve and
# as verbatim stingers. Gitignored. See CLAUDE.md → Voice chain.
RASPUTIN_REFS_DIR=assets/refs

# ── Speech input (M6) ─────────────────────────────────────────────────────────
# brew install whisperkit-cli
WHISPERKIT_MODEL=base.en
RASPUTIN_WAKE_WORD=rasputin
# Hold-to-talk. Tauri global-shortcut syntax.
RASPUTIN_HOTKEY=CommandOrControl+Shift+Space

# ── Claude ────────────────────────────────────────────────────────────────────
# Usually unset — the Agent SDK resolves credentials the same way the CLI does
# (ANTHROPIC_API_KEY, then ANTHROPIC_AUTH_TOKEN, then an `ant auth login`
# profile). Set only to force a specific key.
# ANTHROPIC_API_KEY=
